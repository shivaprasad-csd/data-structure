#include <iostream>
using namespace std;
class node{
    public:
    int data;
    node* next;
    node(int val){
        data=val;
        next=NULL;
    }
};
class stack{
    private:
    node* top;
    public:
    stack(){
        top=NULL;
    }
    bool isempty(){
        if(top == NULL)
        return true;
        else
        return false;
    }
  void push(int val){
   node* newnode= new node(val);
   newnode->next=top;
   top=newnode;
  }
  void pop(){
      if(top==NULL){
          cout<<"stack undrflow\n";
          return;
      }
      node* temp=top;
      cout<<"the popped element from stack is: "<<temp->data<<endl;
      top=top->next;
      delete temp;
  }
  void peek(){
      if(top==NULL){
          cout<<"stack is underflow \n";
          return;
      }
      cout<<"top element in stack is: "<<top->data<<endl;
  }
  void display(){
      if(top==NULL){
          cout<<"stack is empty\n";
          return;
      }
      node* temp=top;
      cout<<"stack elements are: \n";
      while(temp!=NULL){
          cout<<temp->data<<"->";
          temp=temp->next;
      }
      cout<<endl;
  }
};

int main() {
    stack s;
    s.pop();
    s.push(10);
    s.push(20);
    s.push(30);
    s.display();
    s.push(40);
    s.display();
    s.peek();
    s.push(50);
    s.pop();
    s.display();
    return 0;
}
