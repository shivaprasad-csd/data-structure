// Online C++ compiler to run C++ program online
#include <iostream>
# define Max 5
using namespace std;
class stack{
    private:
    int st[Max];
    int top;
    public:
    stack(){
        top=-1;
    }
    bool isempty(){
        if(top==-1)
        return true;
        else
        return false;
    }
    bool isfull(){
        if(top==Max-1)
        return true;
        else
        return false;
    }
    void push(int item){
        if(top==Max-1){
            cout<<"stack overflow\n";
            return;
        }
        top++;
        st[top]=item;
        cout<<item<<endl;
    }
    void pop(){
        if(top==-1){
            cout<<"stack is underflow\n";
            return;
        }
        int ele=st[top];
        top--;
        cout<<"the poped element from stack is: "<<ele;
        cout<<endl;
    }
    void display(){
        if(top==-1){
            cout<<"stack is empty\n";
            return;
        }
        cout<<"stack elements are :\n";
        for(int i=top;i>=0;i--){
            cout<<st[i]<<endl;
        }
    }
    void peek(){
        if(top==-1){
            cout<<"stack is empty \n";
            return;
        }
        cout<<"top element in stack is: "<<st[top]<<endl;
    }
};

int main() {
    stack s;
    if(s.isempty()){
        cout<<" the stack is empty\n";
    }
    s.pop();
    s.push(10);
    s.push(20);
    s.push(30);
    s.display();
    s.push(40);
    s.push(50);
    if(s.isfull()){
        cout<<"the stack is full\n";
    }
    s.peek();
    s.pop();
    s.push(60);
    s.display();
    
    return 0;
}
